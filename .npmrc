# 🔒 Security: disable lifecycle scripts during install
#
# Why: npm supply-chain attacks (Shai-Hulud, Mini Shai-Hulud, node-ipc,
# @tanstack, @antv — all 2025-2026) execute via preinstall / install /
# postinstall hooks. Disabling them blocks the attack vector entirely.
#
# Our deps don't need any lifecycle scripts to function, so this is free.
# If a future dep genuinely needs a hook, run it manually & audit first.
ignore-scripts=true

# Pin lockfile behavior — surface unexpected resolution changes early
save-exact=false
package-lock=true
